<main role="main">
  <div class="container">
    <nav aria-label="Breadcrumb">{{breadcrumbs}}</nav>

    <h1>{{section.name}}</h1>
    {{#if section.description}}
      <p class="text-muted">{{section.description}}</p>
    {{/if}}

    {{#if section.articles}}
      <div class="article-list-wrapper" style="background: var(--bg-card); border: 0.5px solid var(--card-border); border-radius: var(--radius); box-shadow: var(--card-shadow); margin-top: 24px;">
        <ul class="article-list">
          {{#each section.articles}}
            <li class="article-list-item">
              <a href="{{url}}" class="article-list-link">
                {{title}}
              </a>
            </li>
          {{/each}}
        </ul>
      </div>
    {{else}}
      <p class="text-muted">No articles in this section yet.</p>
    {{/if}}

    {{pagination}}
  </div>
</main>

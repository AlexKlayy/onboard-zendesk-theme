<main role="main" class="category-page">
  <div class="category-page-shell">
    <nav class="breadcrumb" aria-label="Breadcrumb">{{breadcrumbs}}</nav>

    <header class="category-head">
      <p class="category-eyebrow">Help center</p>
      <h1 class="category-title">{{category.name}}</h1>
      {{#if category.description}}
        <p class="category-summary">{{category.description}}</p>
      {{/if}}
    </header>

    {{#if sections}}
      <div class="category-sections">
        {{#each sections}}
          <section class="cat-section" data-section-id="{{id}}">
            <header class="cat-section-head">
              <p class="cat-section-kicker"></p>
              <h2 class="cat-section-title">{{name}}</h2>
              {{#if description}}
                <p class="cat-section-desc">{{description}}</p>
              {{/if}}
            </header>

            {{#if articles}}
              <ul class="cat-article-list">
                {{#each articles}}
                  <li class="cat-article">
                    <a class="cat-article-link" href="{{url}}">
                      <span class="cat-article-title">{{title}}</span>
                      <svg class="cat-article-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M5 12h14M13 6l6 6-6 6"/>
                      </svg>
                    </a>
                  </li>
                {{/each}}
              </ul>
            {{else}}
              <p class="cat-section-empty">No articles in this section yet.</p>
            {{/if}}
          </section>
        {{/each}}
      </div>
    {{else}}
      <p class="category-empty">No sections in this category yet.</p>
    {{/if}}
  </div>
</main>

<main role="main" class="request-page">
  <div class="request-page-shell">
    <nav class="breadcrumb" aria-label="Breadcrumb">{{breadcrumbs}}</nav>

    <header class="request-head">
      <p class="request-eyebrow">Support</p>
      <h1 class="request-title">Submit a request</h1>
      <p class="request-summary">Tell us what's going on and our team will get back to you.</p>
    </header>

    <div class="request-form-card">
      <div id="new_request_form"></div>
    </div>
  </div>
</main>

<main role="main">
  <div class="container">
    <nav aria-label="Breadcrumb">{{breadcrumbs}}</nav>

    <h1>Submit a request</h1>
    <p class="text-muted" style="margin-bottom: 32px;">Can't find what you're looking for? Send us a message and we'll get back to you.</p>

    <div class="request-form" style="background: var(--bg-card); border: 0.5px solid var(--card-border); border-radius: var(--radius); padding: 32px; box-shadow: var(--card-shadow);">
      <div id="new-request-form"></div>
    </div>
  </div>
</main>

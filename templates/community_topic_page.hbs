<main role="main">
  <div class="container">
    <h1>{{topic.name}}</h1>
    {{#if topic.description}}
      <p class="text-muted">{{topic.description}}</p>
    {{/if}}
    {{#if posts}}
      <ul class="article-list" style="background: var(--bg-card); border: 0.5px solid var(--card-border); border-radius: var(--radius); box-shadow: var(--card-shadow); margin-top: 24px;">
        {{#each posts}}
          <li class="article-list-item">
            <a href="{{url}}" class="article-list-link">{{title}}</a>
          </li>
        {{/each}}
      </ul>
    {{/if}}
  </div>
</main>
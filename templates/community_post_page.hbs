<main role="main">
  <div class="container">
    <div class="community-post">
      {{#if post}}
        <h1>{{post.title}}</h1>
        <div class="article-meta">
          <span class="article-author">{{post.author.name}}</span>
          <span class="article-date">{{date post.created_at}}</span>
        </div>
        <div class="article-content" style="margin-top: 20px;">
          {{post.details}}
        </div>
      {{/if}}
    </div>
  </div>
</main>

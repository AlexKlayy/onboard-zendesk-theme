<header class="header" role="banner">
  <div class="header-inner">
    <div class="logo">
      {{#link 'help_center' class='logo-link'}}
        <img src="{{asset 'logo.png'}}" alt="{{help_center.name}}">
      {{/link}}
    </div>

    <nav class="header-nav" aria-label="Primary">
      {{#link 'new_request' class='nav-link nav-link-cta'}}Submit a request{{/link}}
      {{#if signed_in}}
        <span class="user-info">{{user_name}}</span>
        {{#link 'sign_out' class='nav-link'}}Sign out{{/link}}
      {{else}}
        {{#link 'sign_in' class='nav-link'}}Sign in{{/link}}
      {{/if}}
    </nav>
  </div>
</header>
